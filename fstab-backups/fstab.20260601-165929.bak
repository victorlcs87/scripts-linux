# /etc/fstab: static file system information.
#
# Use 'blkid' to print the universally unique identifier for a device; this may
# be used with UUID= as a more robust way to name devices that works even if
# disks are added and removed. See fstab(5).
#
# <file system>             <mount point>  <type>  <options>  <dump>  <pass>
UUID=a24196ce-be91-45ca-9457-783748bd7c42 swap           swap    defaults   0 0
UUID=1C3D-6F6A                            /boot          vfat    defaults,umask=0077 0 2
UUID=85df2bd0-a966-45d9-b8a8-933b7a8a9e37 /              btrfs   subvol=/@,defaults,noatime,compress=zstd:1 0 0
UUID=85df2bd0-a966-45d9-b8a8-933b7a8a9e37 /home          btrfs   subvol=/@home,defaults,noatime,compress=zstd:1 0 0
UUID=85df2bd0-a966-45d9-b8a8-933b7a8a9e37 /root          btrfs   subvol=/@root,defaults,noatime,compress=zstd:1 0 0
UUID=85df2bd0-a966-45d9-b8a8-933b7a8a9e37 /srv           btrfs   subvol=/@srv,defaults,noatime,compress=zstd:1 0 0
UUID=85df2bd0-a966-45d9-b8a8-933b7a8a9e37 /var/cache     btrfs   subvol=/@cache,defaults,noatime,compress=zstd:1 0 0
UUID=85df2bd0-a966-45d9-b8a8-933b7a8a9e37 /var/tmp       btrfs   subvol=/@tmp,defaults,noatime,compress=zstd:1 0 0
UUID=85df2bd0-a966-45d9-b8a8-933b7a8a9e37 /var/log       btrfs   subvol=/@log,defaults,noatime,compress=zstd:1 0 0
tmpfs                                     /tmp           tmpfs   defaults,noatime,mode=1777 0 0
